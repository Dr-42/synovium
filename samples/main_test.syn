// main_test.syn
fnc printf(fmt: str, ...);

Matrix : type := math.linal.mat.Matrix;
Vec2 : type := math.linal.vec.Vec2;

fnc main() = i32 {
    defer printf("--- DAG Auto-Loader Test Complete ---\n");

    printf("Booting main_test.syn...\n");

    // The DAG hits 'Matrix', halts, loads 'Matrix.syn', parses it, 
    // injects the AST into the queue, and resumes sorting!
    m1 : Matrix = Matrix{ .a = 10, .b = 20 };
    m2 : Matrix = Matrix{ .a = 5,  .b = 5 };

    // Uses the operator overload defined in Matrix.syn
    sum : Matrix = m1 + m2;
    sum.scale(2);

    printf("Dynamically Loaded Matrix Sum: a=%d, b=%d\n", sum.a, sum.b);

    v1 : Vec2 = Vec2{ .x = 10.5, .y = 20.5 };
    v2 : Vec2 = Vec2{ .x = 5.0,  .y = 5.0 };

    dot : f64 = v1 * v2;
    printf("Vector 1 %f, %f\n", v1.x, v1.y);
    printf("Vector 2 %f, %f\n", v2.x, v2.y);
    printf("Dot Product: %f\n", dot);

    ret 0;
}
