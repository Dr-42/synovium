// test.syn - Synovium Phase 3 100% Mastery

// 1. Data Structures & Enums (Tagged Unions)
struct Vec3 {
    x : f64,
    y : f64,
    z : f64,
}

enum Status {
    Idle,
    Running(f64),
    Error(str),
}

// 2. Impl Blocks & Methods
impl Vec3 {
    // Note: 'Self' is dynamically injected into the scope by evaluateImplDecl!
    fnc magnitude_sq(self : *Self) = f64 {
        ret self.x * self.x + self.y * self.y + self.z * self.z;
    }
}

// 3. Generic Monomorphization
fnc identity(T : type, val : T) = T {
    ret val;
}

// 4. Main Execution
fnc main() = void {
    // A. Pattern Matching & Tagged Unions
    stat : Status = Status.Running(100.5);
    
    speed_check : f64 = match stat {
        Status.Idle -> { 0.0 },
        Status.Running(speed) -> { speed }, // Binds 'speed' as f64
        Status.Error(err) -> { -1.0 },
    };

    // B. Struct Initialization & Pointer Generation
    v1 : Vec3 = Vec3 {
        .x = speed_check,
        .y = 20.0,
        .z = 30.0
    };
    
    v_ptr : *Vec3 = &v1;
    
    // C. Method Call & Dynamic Resolution
    // Resolves magnitude_sq from the Vec3 Impl block!
    mag : f64 = v_ptr.magnitude_sq(); 
    
    // D. Loops and Ranges
    counter : i32 ~= 0;
    loop (i : i32 = 0...10) {
        counter += 1;
    }
    
    // E. Generics and Explicit Casts
    final_val : i32 = counter as i32;
    verified : i32 = identity(i32, final_val);
}
