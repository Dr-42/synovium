// test.syn - Synovium Syntax Highlighting Test

// Comptime constant
THRESHOLD : i32 := 100;

struct Mat3 {
    r1 : Vec3,
    r2 : Vec3,
    r3 : Vec3,
}

impl Vec3 {
    fnc add(self: *Self, other: Vec3) {
        self + other
    }
}

// Struct definition
struct Vec3 {
    x : f64,
    y : f64,
    z : f64,
}

// Enum definition with data variants
enum Status {
    Idle,
    Running(f64),
    Error(str),
}

// Impl block with methods
impl Vec3 {
    // Comptime function (constructor)
    fnc new(x : f64, y : f64, z : f64) := Vec3 {
        ret Vec3 {
            .x = x,
            .y = y,
            .z = z
        };
    }

    // Runtime method with bubbling return
    fnc magnitude_sq(self : *Self) = f64 {
        self.x * self.x + self.y * self.y + self.z * self.z // Bubbles!
    }
}

// Standard runtime function
fnc process_data(input : [i32; :]) = [i32; :] {
    // Mutable variable
    counter : i32 ~= 0;

    // Loop with range and yield
    results : [i32; :] = loop (i : i32 = 0...10) {
        if i % 2 == 0 {
            counter ~= counter + 1;
            yld i * 2;
        } elif i == 9 {
            brk;
        } else {
            yld i;
        }
    };

    ret results;
}

// Pattern matching and casting
fnc check_status(s : Status) = str {
    match s {
        Status.Idle -> { "System is idle" },
        Status.Running(speed) -> { 
            // Casting example
            metric : i32 = speed as i32;
            "System is running" 
        },
        Status.Error(msg) -> { msg },
    }
}

// Main execution
fnc main() {
    v1 : Vec3 = Vec3.new(1.0, 2.0, 3.0);
    m1 : Mat3 = Mat3.unit();
    m1.r1.z = 7.98;
    v1.z = 1.5;
    mag : f64 = v1.magnitude_sq();
    
    // Bubbling error test
    val : i32 = some_fallible_call()?;
}
