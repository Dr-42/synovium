// ==========================================
// 1. EXTERNAL FFI & VARIADICS
// ==========================================
fnc printf(fmt: str, ...);

// ==========================================
// 2. TAGGED UNIONS (ENUMS) & PAYLOADS
// ==========================================
enum State {
    Alive(f64),    // Payload: Health
    Dead(i32),     // Payload: Time of death
    Invincible
}

// ==========================================
// 3. STRUCTS & NESTED DATA
// ==========================================
struct Player {
    id: i32,
    state: State,
    score: i32
}

// ==========================================
// 4. IMPL BLOCKS, METHODS, & AUTO-DEREF
// ==========================================
impl Player {
    fnc take_hit(self: *Player, damage: f64) {
        // Match statement with block bubbling and payload extraction!
        new_state : State := match self.state {
            State.Alive(health) -> {
                rem : f64 := health - damage;
                if rem <= 0.0 {
                    printf("Player %d died!\n", self.id);
                    State.Dead(99) // Bubbles out
                } else {
                    State.Alive(rem) // Bubbles out
                }
            },
            State.Dead(time) -> {
                printf("Stop hitting him, he died at %d!\n", time);
                self.state // Bubbles out (No change)
            },
            State.Invincible -> {
                printf("Tink! Armor deflected %f damage.\n", damage);
                self.state // Bubbles out
            }
        };
        
        self.state = new_state;
    }
}

// ==========================================
// 5. COMPILE-TIME GENERICS (MONOMORPHIZATION)
// ==========================================
fnc unwrap_or(T: type, val: *T, fallback: T) = T {
    // If pointer is not null (not yet natively supported, assuming true for test)
    ret *val; 
}

// ==========================================
// 6. MAIN EXECUTION & CONTROL FLOW
// ==========================================
fnc main() = i32 {
    // Variable Decls, Struct Init, Enum Constructors
    p: Player = Player {
        .id = 42,
        .state = State.Alive(100.0),
        .score = 0
    };

    // Arrays & Strings
    messages : [str; 2] := ["Combat Start!", "Combat End!"];
    printf("%s\n", messages[0]);

    // Loop with range and break/bubble
    loop (i: i32 = 0...5) {
        if i == 2 {
            p.state = State.Invincible;
        }

        // Pointers & Method Calls
        p_ptr : *Player := &p;
        p_ptr.take_hit(60.0);

        if i == 3 {
            brk; // Breaks out of the loop
        }
    }

    // Generic Instantiation
    bonus : i32 := 500;
    bonus_ptr : *i32 := &bonus;
    final_score : i32 := p.score + unwrap_or(i32, bonus_ptr, 0);

    printf("Final Score: %d\n", final_score);
    ret 0;
}
