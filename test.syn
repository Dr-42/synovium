// test.syn - Synovium Unified AST Master Test

// 1. Comptime Constants
THRESHOLD : i32 := 100;

// 2. Data Structures
struct Manager {
    id : i32,
    active : bln,
}

struct Motor {
    rpm : f64,
    id : i32,
}

struct Vec3 {
    x : f64,
    y : f64,
    z : f64,
}

struct Mat3 {
    r1 : Vec3,
    r2 : Vec3,
    r3 : Vec3,
}

// 3. Enums
enum Status {
    Idle,
    Running(f64),
    Error(str),
}

// 4. Impl Blocks & Methods
impl Vec3 {
    fnc new(x : f64, y : f64, z : f64) := Vec3 {
        ret Vec3 {
            .x = x,
            .y = y,
            .z = z
        };
    }

    fnc magnitude_sq(self : *Self) = f64 {
        self.x * self.x + self.y * self.y + self.z * self.z
    }
}

// 5. Higher-Order Functions (Function Types as Parameters)
fnc apply_transform(val : i32, transform : fnc(i32) = i32) = i32 {
    ret transform(val);
}

// 6. Main Execution Block
fnc main() = i32 {
    // A. Simple Anonymous Lambda Assignment
    double : fnc(i32) = i32 = fnc(x : i32) = i32 {
        ret x * 2;
    };

    // B. Nested Named Function (Closure)
    next : fnc(type, *Manager, i32) = i32 := fnc next_motor(T : type, m : *Manager, val : i32) = i32 {
        // Test internal mutation and compound assignment
        temp : i32 ~= val;
        temp += 10;
        ret temp;
    };

    // C. Array of Function Pointers
    // (Must be initialized per Synovium's strict EBNF!)
    handlers : [fnc(i32) = str; 5] = get_handlers();

    // D. Struct Initialization
    mgr : Manager = Manager {
        .id = 42,
        .active = true
    };

    // E. Calling nested function with comptime type parameter
    n_motor : i32 ~= next(Motor, &mgr, 24);

    // F. Looping, Yielding, and Higher-Order execution
    results : [i32; :] = loop (i : i32 = 0...10) {
        if i % 2 == 0 {
            n_motor += 1;
            yld apply_transform(n_motor, double);
        } elif i == 9 {
            brk;
        } else {
            yld i;
        }
    };

    // G. Object Methods and Bubbling
    v1 : Vec3 = Vec3.new(1.0, 2.0, 3.0);
    mag : f64 = v1.magnitude_sq()?;
    
    // H. Pattern Matching and Casting
    stat : Status = Status.Running(mag);
    msg : str = match stat {
        Status.Idle -> { "System is idle" },
        Status.Running(speed) -> { 
            metric : i32 = speed as i32;
            "System is running" 
        },
        Status.Error(err) -> { err },
    };

    ret n_motor;
}
