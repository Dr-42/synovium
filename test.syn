// test.syn - Synovium Semantic Engine Master Test

struct Mat3 {
    r1 : Vec3,
    r2 : Vec3,
    r3 : Vec3,
}

// 1. Struct Memory Layout
struct Vec3 {
    x : f64,
    y : f64,
    z : f64,
}

// 2. Generic Comptime Template!
// Because 'T' is marked as a `type`, the engine defers checking this 
// until it is actually called with a concrete type below.
fnc identity(T : type, val : T) = T {
    ret val;
}

// 3. Main Execution Block
fnc main() {
    // A. Mutability and Primitive Promotion (i32 implicitly promotes to f64)
    base : f64 ~= 10.5;
    modifier : i32 = 2;
    base += modifier; 

    // B. Struct Initialization (Validates fields exist and types match)
    v1 : Vec3 = Vec3 {
        .x = base,
        .y = 20.0,
        .z = 30.0
    };

    // C. Field Access & Generic Monomorphization!
    // We pass the type 'f64' and the field 'v1.y'.
    // The engine clones 'identity', substitutes T for f64, and type-checks it.
    y_val : f64 = identity(f64, v1.y);
    z_n : i32 = 7 + 9;
    z_val : i32 = identity(i32, z_n);

    // D. Block Bubbling & Strict Branch Verification
    final : f64 = if true {
        temp : f64 = y_val * 2.0;
        temp // Bubbles out of the block!
    } else {
        0.0  // Else branch strictly matches the If branch type (f64)
    };
}
