// --- SYNTHEX EBNF ROOT ---

<Program>      ::= <Declaration>*
<Declaration>  ::= <VariableDecl> ";"
                 | <StructDecl>
                 | <EnumDecl>
                 | <ImplBlock>
                 | <FuncDecl>

<VariableDecl> ::= <Identifier> ":" <Type> <AssignOp> <Expression>
<AssignOp>     ::= "="   /* Immutable Runtime */
                 | "~="  /* Mutable Runtime */
                 | ":="  /* Comptime Constant */

<StructDecl>   ::= "struct" <Identifier> "{" <FieldList>? "}"
<FieldList>    ::= <Field> ( "," <Field> )* ","?
<Field>        ::= <Identifier> ":" <Type>

<EnumDecl>     ::= "enum" <Identifier> "{" <VariantList>? "}"
<VariantList>  ::= <Variant> ( "," <Variant> )* ","?
<Variant>      ::= <Identifier> ( "(" <Type> ")" )?

<ImplBlock>    ::= "impl" <Identifier> ( "for" <TypeList> )? "{" <FuncDecl>* "}"
<TypeList>     ::= "(" <Type> ( "," <Type> )* ")" | <Type>

<FuncDecl>     ::= "fnc" <Identifier> "(" <ParamList>? ")" ( <ReturnOp> <Type> )? <Block>
<ParamList>    ::= <Param> ( "," <Param> )* ","?
<Param>        ::= <Identifier> ":" <Type>
<ReturnOp>     ::= ":=" | "="

<Block>        ::= "{" <Statement>* "}"
<Statement>    ::= <VariableDecl> ";" 
                 | "ret" <Expression>? ";" 
                 | <Expression> ";" /* For function calls, assignments, etc. */

<Type>         ::= "*"* "&"* <Identifier> /* Handles pointers *Self, &i32 */
<Identifier>   ::= [a-zA-Z_] [a-zA-Z0-9_]*
