{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tree_sitter_synovium",
      "camelcase": "TreeSitterSynovium",
      "title": "TreeSitter Synovium",
      "scope": "source.tree_sitter_synovium",
      "file-types": [
        "syn"
      ],
      "injection-regex": "^tree_sitter_synovium$",
      "class-name": "TreeSitterTreeSitterSynovium"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "BSD-2-Clause",
    "description": "Treesitter parser for Synovium",
    "authors": [
      {
        "name": "Dr-42",
        "email": "royspandan1@gmail.com",
        "url": "https://github.com/Dr-42"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-tree_sitter_synovium",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}